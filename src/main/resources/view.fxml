<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.CryptoController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Aplikacja Kryptograficzna" style="-fx-font-size: 20px; -fx-font-weight: bold;" />

    <VBox spacing="5.0">
        <Label text="Tekst wejściowy:" />
        <TextArea fx:id="inputField" prefHeight="100.0" promptText="Wpisz tekst..." />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Klucz szyfrujący:" />
        <TextField fx:id="keyField" promptText="Hasło / Klucz" />
    </VBox>

    <HBox alignment="CENTER" spacing="20.0">
        <Button onAction="#handleEncrypt" text="ZASZYFRUJ" prefWidth="120.0"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-cursor: hand;" />
        <Button onAction="#handleDecrypt" text="ODSZYFRUJ" prefWidth="120.0"
                style="-fx-background-color: #F44336; -fx-text-fill: white; -fx-cursor: hand;" />
    </HBox>

    <VBox spacing="5.0">
        <Label text="Wynik operacji:" />
        <TextArea fx:id="outputField" editable="false" prefHeight="100.0"
                  style="-fx-control-inner-background: #eeeeee;" />
    </VBox>
</VBox>
