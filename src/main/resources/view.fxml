<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="8"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.CryptoController">
    <padding>
        <Insets top="10" right="12" bottom="10" left="12"/>
    </padding>

    <!-- ═══ SEKCJA: KLUCZ ═══ -->
    <TitledPane text="Klucz" collapsible="false" expanded="true">
        <VBox spacing="6">
            <padding><Insets top="6" right="8" bottom="6" left="8"/></padding>

            <!-- Klucz publiczny -->
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Klucz Publiczny g^x mod p:" minWidth="180"/>
                <TextField fx:id="publicKeyArea" editable="false"
                           HBox.hgrow="ALWAYS"
                           style="-fx-font-family: monospace; -fx-font-size: 11px;"/>
            </HBox>

            <!-- Klucz prywatny -->
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Klucz Prywatny x:" minWidth="180"/>
                <TextField fx:id="privateKeyArea" editable="false"
                           HBox.hgrow="ALWAYS"
                           style="-fx-font-family: monospace; -fx-font-size: 11px;"/>
            </HBox>

            <!-- MOD N -->
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="MOD N (q):" minWidth="180"/>
                <TextField fx:id="modNField" editable="false"
                           HBox.hgrow="ALWAYS"
                           style="-fx-font-family: monospace; -fx-font-size: 11px;"/>
            </HBox>

            <!-- Generuj klucze -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Wygeneruj wartości kluczy" minWidth="180"/>
                <fx:define>
                    <ToggleGroup fx:id="keySizeGroup"/>
                </fx:define>
                <RadioButton fx:id="rb1024" text="1024/160"
                             toggleGroup="$keySizeGroup" selected="true"/>
                <RadioButton fx:id="rb2048" text="2048/256"
                             toggleGroup="$keySizeGroup"/>
                <Button text="Generuj klucze" onAction="#handleGenerateKeys" prefWidth="130"/>
                <ProgressIndicator fx:id="spinner" prefWidth="20" prefHeight="20" visible="false"/>
            </HBox>

            <!-- Wczytaj / Zapisz klucze -->
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Wczytaj klucze z pliku" minWidth="180"/>
                <TextField fx:id="loadKeyFileField" promptText="Nazwa pliku kluczy"
                           prefWidth="160" style="-fx-font-size: 11px;"/>
                <Button text="Wczytaj" onAction="#handleLoadKeys" prefWidth="80"/>
                <Label text="Zapisz klucze do pliku" style="-fx-padding: 0 0 0 30;"/>
                <TextField fx:id="saveKeyFileField" promptText="Nazwa pliku kluczy"
                           prefWidth="160" style="-fx-font-size: 11px;"/>
                <Button text="Zapisz" onAction="#handleSaveKeys" prefWidth="80"/>
            </HBox>

        </VBox>
    </TitledPane>

    <!-- ═══ SEKCJA: PODPIS / WERYFIKACJA ═══ -->
    <TitledPane text="Podpis/Weryfikacja" collapsible="false" expanded="true"
                VBox.vgrow="ALWAYS">
        <VBox spacing="6" VBox.vgrow="ALWAYS">
            <padding><Insets top="6" right="8" bottom="6" left="8"/></padding>

            <!-- Nagłówki otwórz plik -->
            <HBox spacing="8">
                <VBox HBox.hgrow="ALWAYS">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Otwórz plik zawierający tekst jawny"/>
                        <Region HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <HBox spacing="6">
                        <TextField fx:id="openPlainFileField" promptText="Ścieżka do pliku"
                                   HBox.hgrow="ALWAYS" style="-fx-font-size: 11px;"/>
                        <Button text="Otwórz" onAction="#handleOpenFile" prefWidth="70"/>
                    </HBox>
                </VBox>

                <VBox minWidth="130" maxWidth="130"/>

                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Otwórz plik zawierający podpis"/>
                    <HBox spacing="6">
                        <TextField fx:id="openSigFileField" promptText="Nazwa pliku z podpisem"
                                   HBox.hgrow="ALWAYS" style="-fx-font-size: 11px;"/>
                        <Button text="Otwórz" onAction="#handleLoadSignature" prefWidth="70"/>
                    </HBox>
                </VBox>
            </HBox>

            <!-- Główny obszar: tekst jawny | przyciski | podpis -->
            <HBox spacing="10" VBox.vgrow="ALWAYS">

                <!-- Lewa: tekst jawny -->
                <TextArea fx:id="messageArea"
                          promptText="Tekst jawny..."
                          wrapText="true"
                          HBox.hgrow="ALWAYS"
                          prefHeight="220"
                          style="-fx-font-family: monospace; -fx-font-size: 11px;"/>

                <!-- Środek: przyciski + radio -->
                <VBox spacing="14" alignment="CENTER" minWidth="130" maxWidth="130">
                    <Button text="Podpisuj ->" onAction="#handleSign"
                            prefWidth="120" prefHeight="32"/>
                    <Button text="&lt;- Weryfikuj" onAction="#handleVerify"
                            prefWidth="120" prefHeight="32"/>
                    <Separator/>
                    <fx:define>
                        <ToggleGroup fx:id="modeGroup"/>
                    </fx:define>
                    <RadioButton fx:id="modePlik" text="Plik"
                                 toggleGroup="$modeGroup" selected="true"/>
                    <RadioButton fx:id="modeOkno" text="Okno"
                                 toggleGroup="$modeGroup"/>
                </VBox>

                <!-- Prawa: podpis -->
                <TextArea fx:id="signatureArea"
                          promptText="Podpis (r:s hex)..."
                          wrapText="true"
                          HBox.hgrow="ALWAYS"
                          prefHeight="220"
                          style="-fx-font-family: monospace; -fx-font-size: 11px;"/>

            </HBox>

            <!-- Dolny pasek: zapisz tekst | zapisz podpis -->
            <HBox spacing="8">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Zapisz plik zawierający tekst jawny"/>
                    <HBox spacing="6">
                        <TextField fx:id="savePlainFileField"
                                   promptText="Nazwa pliku z tekstem jawnym"
                                   HBox.hgrow="ALWAYS" style="-fx-font-size: 11px;"/>
                        <Button text="Zapisz" onAction="#handleSavePlain" prefWidth="70"/>
                    </HBox>
                </VBox>

                <VBox minWidth="130" maxWidth="130"/>

                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Zapisz plik zawierający podpis"/>
                    <HBox spacing="6">
                        <TextField fx:id="saveSigFileField"
                                   promptText="Nazwa pliku z podpisem"
                                   HBox.hgrow="ALWAYS" style="-fx-font-size: 11px;"/>
                        <Button text="Zapisz" onAction="#handleSaveSignature" prefWidth="70"/>
                    </HBox>
                </VBox>
            </HBox>

        </VBox>
    </TitledPane>

    <!-- ═══ STATUS ═══ -->
    <Label fx:id="statusLabel" text="Gotowy."
           wrapText="true"
           style="-fx-font-size: 11px; -fx-text-fill: #333;"/>

</VBox>
